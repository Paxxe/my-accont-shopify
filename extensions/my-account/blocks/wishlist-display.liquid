{% if customer %}
<div id="ma-wishlist-root" style="display:none;">
  <h2 class="ma-wl-title">{{ block.settings.title }}</h2>
  <div id="ma-wishlist-grid" class="ma-wl-grid"></div>
</div>

<style>
  .ma-wl-title { font-size: 18px; font-weight: 700; margin: 0 0 16px; }
  .ma-wl-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 16px; }
  .ma-wl-card { display: block; text-decoration: none; color: inherit; border: 1px solid #e5e5e5; border-radius: 8px; overflow: hidden; transition: box-shadow 0.2s; }
  .ma-wl-card:hover { box-shadow: 0 4px 14px rgba(0,0,0,0.09); }
  .ma-wl-card img { width: 100%; aspect-ratio: 1; object-fit: cover; display: block; background: #f5f5f5; }
  .ma-wl-card-no-img { width: 100%; aspect-ratio: 1; background: #f0f0f0; display: block; }
  .ma-wl-card-body { padding: 10px 12px; }
  .ma-wl-card-name { font-size: 13px; font-weight: 500; margin: 0 0 4px; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; }
  .ma-wl-card-price { font-size: 13px; color: #555; margin: 0; }
</style>

<script>
(function () {
  var root = document.getElementById('ma-wishlist-root');
  var grid = document.getElementById('ma-wishlist-grid');
  var customerId = '{{ customer.id }}';
  var PROXY = '/apps/my-account';
  var max = {{ block.settings.max_products }};

  fetch(PROXY + '?action=wishlist&customerId=' + encodeURIComponent(customerId))
    .then(function (r) { return r.json(); })
    .then(function (data) {
      var products = (data.products || []).slice(0, max);
      if (products.length === 0) return;
      root.style.display = 'block';
      grid.innerHTML = products.map(function (p) {
        var img = p.featuredImage;
        var price = p.priceRange && p.priceRange.minVariantPrice;
        var formattedPrice = price
          ? parseFloat(price.amount).toLocaleString('it-IT', { style: 'currency', currency: price.currencyCode })
          : '';
        var url = p.onlineStoreUrl || ('/products/' + p.handle);
        return '<a href="' + url + '" class="ma-wl-card">' +
          (img
            ? '<img src="' + img.url + '" alt="' + (img.altText || p.title) + '">'
            : '<div class="ma-wl-card-no-img"></div>') +
          '<div class="ma-wl-card-body">' +
            '<p class="ma-wl-card-name">' + p.title + '</p>' +
            '<p class="ma-wl-card-price">' + formattedPrice + '</p>' +
          '</div>' +
        '</a>';
      }).join('');
    })
    .catch(function () {});
})();
</script>
{% endif %}

{% schema %}
{
  "name": "Prodotti preferiti",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Titolo sezione",
      "default": "I tuoi preferiti"
    },
    {
      "type": "range",
      "id": "max_products",
      "label": "Numero massimo prodotti",
      "min": 2,
      "max": 12,
      "step": 2,
      "default": 6
    }
  ]
}
{% endschema %}
